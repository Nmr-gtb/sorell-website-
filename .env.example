# ============================================
# Sorell - Variables d'environnement
# ============================================
# Copier ce fichier en .env.local et remplir les valeurs

# --- Anthropic (IA) ---
# Cle API depuis https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Supabase ---
# Depuis https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Cle service_role (JAMAIS exposee cote client) - meme page Settings > API
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (Email) ---
# Cle API depuis https://resend.com/api-keys
RESEND_API_KEY=
# Secret du webhook Resend (bounces/complaints) - https://resend.com/webhooks
RESEND_WEBHOOK_SECRET=

# --- Stripe (Paiement) ---
# Cle secrete depuis https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Secret du webhook Stripe - https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# --- CRON ---
# Secret partage avec cron-job.org pour authentifier les appels CRON
CRON_SECRET=

# --- Upstash Redis (Rate Limiting) ---
# Depuis https://console.upstash.com/ > votre base Redis > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Unsubscribe ---
# Secret utilise pour signer les liens de desabonnement
UNSUBSCRIBE_SECRET=

# --- Notion (Sync) ---
# Cle API Notion depuis https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key
# ID de la database "Taches Sorell"
NOTION_DATABASE_ID=your_notion_database_id
# ID de la database "Utilisateurs Sorell"
NOTION_USERS_DB_ID=your_notion_users_db_id
# ID de la database "Activite Sorell"
NOTION_ACTIVITY_DB_ID=your_notion_activity_db_id

# --- Telegram ---
# Token du bot Eva depuis @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Secret du webhook Telegram Eva
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret
# ID de ton chat Telegram (ton user ID)
TELEGRAM_USER_ID=your_telegram_user_id
# Token du bot Jade depuis @BotFather
TELEGRAM_JADE_BOT_TOKEN=your_telegram_jade_bot_token
# Secret du webhook Telegram Jade
TELEGRAM_JADE_WEBHOOK_SECRET=your_telegram_jade_webhook_secret

# --- Admin ---
# Email du compte admin
ADMIN_EMAIL=your_admin_email
# Hash bcrypt du mot de passe admin
ADMIN_PASSWORD_HASH=your_bcrypt_hash
# Secret JWT pour les sessions admin
ADMIN_JWT_SECRET=your_jwt_secret

# --- Emelia (Cold Email) ---
# Cle API Emelia depuis https://app.emelia.io/settings
EMELIA_API_KEY=your_emelia_api_key
# IDs des campagnes autorisees (separees par des virgules)
# IMPORTANT : seules ces campagnes seront synchronisees vers Notion
EMELIA_CAMPAIGN_IDS=

# --- Notion Prospection ---
# ID de la database "Prospection Cold Email" dans Notion
# (deja utilise dans lib/emelia-sync.ts)

# --- App ---
# URL publique de l'application
NEXT_PUBLIC_APP_URL=https://your-domain.com
